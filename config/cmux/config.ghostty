theme = "Kanagawa Wave"
window-theme = dark
window-padding-color = background

confirm-close-surface = false

font-family = "SF Mono"
font-feature = -dlig
font-size = 13

cursor-color = #7e9cd8
selection-background = #2d4f67
selection-foreground = rgb(9, 9, 7)

split-divider-color = #2a2a37
unfocused-split-opacity = 0.7
unfocused-split-fill = #16161d
