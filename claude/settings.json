{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MISE_YES": "1",
    "DIRENV_LOG_FORMAT": ""
  },
  "permissions": {
    "allow": [
      "mcp__pencil",
      "Bash(sudo pmset *)",
      "Bash(pmset *)",
      "Bash(ls:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(make:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(date:*)",
      "Bash(env:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(pwd:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(test:*)",
      "Bash([[:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(tree:*)",
      "Bash(bat:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(base64:*)",
      "Bash(openssl:*)",
      "Bash(go:*)",
      "Bash(golangci-lint:*)",
      "Bash(dart:*)",
      "Bash(fvm flutter:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl config:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(kubectl api-versions:*)",
      "Bash(kubectl version:*)",
      "Bash(kubectl diff:*)",
      "Bash(kubectx:*)",
      "Bash(kubens:*)",
      "Bash(stern:*)",
      "Bash(helm list:*)",
      "Bash(helm status:*)",
      "Bash(helm get:*)",
      "Bash(helm show:*)",
      "Bash(helm search:*)",
      "Bash(helm template:*)",
      "Bash(helm lint:*)",
      "Bash(helm diff:*)",
      "Bash(helm repo:*)",
      "Bash(terraform init:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform show:*)",
      "Bash(terraform state list:*)",
      "Bash(terraform state show:*)",
      "Bash(terraform output:*)",
      "Bash(terraform providers:*)",
      "Bash(terraform version:*)",
      "Bash(terraform workspace list:*)",
      "Bash(terraform workspace show:*)",
      "Bash(gcloud config:*)",
      "Bash(gcloud projects list:*)",
      "Bash(gcloud auth:*)",
      "Bash(gcloud container clusters list:*)",
      "Bash(psql:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(mise:*)",
      "Bash(direnv:*)",
      "Bash(ghq:*)",
      "Bash(fzf:*)",
      "Bash(delta:*)",
      "Bash(timeout:*)",
      "Bash(shellcheck:*)",
      "WebFetch(domain:*)",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(sops:*)",
      "Bash(op:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/master.key)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if printf '%s\\n' \"$CLAUDE_TOOL_INPUT\" | jq -r '.command' 2>/dev/null | grep -qE '(rm\\s+-rf\\s+(/|~|\\$HOME|/usr|/etc|/var|/opt|/System)|>\\s*/dev/sd|mkfs|dd\\s+if=)'; then echo 'BLOCK: Destructive system command detected' >&2; exit 2; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
